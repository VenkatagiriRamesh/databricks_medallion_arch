# ==============================================================================
# Databricks Medallion Architecture — .gitignore
# ==============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# ── Jupyter / Databricks Notebooks ────────────────────────────────────────────
.ipynb_checkpoints/
*.nbconvert.*

# ── IDE & Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── Databricks ────────────────────────────────────────────────────────────────
.databricks/
*.pyc

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.local
*.pem
*.key

# ── Data (do not commit raw datasets) ─────────────────────────────────────────
data/
*.csv
*.parquet
